    <script>
        // 实现内容切换功能
        document.addEventListener('DOMContentLoaded', function() {
            // 获取所有导航项
            const navItems = document.querySelectorAll('.data-nav .nav-item');
            // 获取所有内容区域
            const tabContents = document.querySelectorAll('.data-content .tab-content');
            // 获取导航栏的ul元素
            const navUl = document.querySelector('.data-nav ul');
            
            // 为每个导航项添加点击事件监听
            navItems.forEach(item => {
                item.addEventListener('click', function() {
                    // 移除所有导航项的active类
                    navItems.forEach(nav => nav.classList.remove('active'));
                    // 为当前点击的导航项添加active类
                    this.classList.add('active');
                    
                    // 获取当前导航项对应的内容区域ID
                    const tabId = this.getAttribute('data-tab');
                    
                    // 移除所有内容区域的active类
                    tabContents.forEach(content => content.classList.remove('active'));
                    // 为对应的内容区域添加active类
                    document.getElementById(tabId).classList.add('active');
                    
                    // 添加ul的active类，切换背景颜色
                    navUl.classList.add('active');
                });
            });
            
            // 页面加载时检查是否有默认选中的导航项
            const hasActiveNav = Array.from(navItems).some(item => item.classList.contains('active'));
            if (hasActiveNav) {
                navUl.classList.add('active');
            }
            
            // 复试名单年份导航功能
            const yearItems = document.querySelectorAll('.year-nav .year-item');
            const yearContents = document.querySelectorAll('.year-content');
            
            // 为每个年份导航项添加点击事件监听
            yearItems.forEach(item => {
                item.addEventListener('click', function() {
                    // 移除所有年份导航项的active类
                    yearItems.forEach(year => year.classList.remove('active'));
                    // 为当前点击的年份导航项添加active类
                    this.classList.add('active');
                    
                    // 获取当前年份对应的内容区域ID
                    const yearId = this.getAttribute('data-year');
                    
                    // 移除所有年份内容区域的active类
                    yearContents.forEach(content => content.classList.remove('active'));
                    // 为对应的内容区域添加active类
                    document.getElementById('year-' + yearId).classList.add('active');
                    
                    // 特殊处理2024年：显示表格，隐藏原有内容
                    if (yearId === '2024') {
                        const year2024Content = document.getElementById('year-2024');
                        const table = year2024Content.querySelector('.admission-table');
                        const originalH3 = year2024Content.querySelector('h3');
                        const originalP = year2024Content.querySelector('p');
                        
                        // 更新标题
                        originalH3.textContent = '2024年普通一志愿复试名单（14人）';
                        
                        // 隐藏原有段落
                        originalP.style.display = 'none';
                        
                        // 显示表格
                        table.style.display = 'table';
                    } else if (yearId === '2023') {
                        // 2023年的表格已经直接添加到HTML中，不需要特殊处理
                        const year2023Content = document.getElementById('year-2023');
                        const originalP = year2023Content.querySelector('p');
                        if (originalP) {
                            originalP.style.display = 'none';
                        }
                    } else {
                        // 对于其他年份，恢复默认状态
                        yearContents.forEach(content => {
                            const table = content.querySelector('.admission-table');
                            const originalP = content.querySelector('p');
                            if (table) {
                                table.style.display = 'none';
                            }
                            if (originalP) {
                                originalP.style.display = 'block';
                            }
                        });
                    }
                });
            });
        });
    </script>
    
    <!-- 引入Chart.js库 -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <!-- 创建折线图 -->
    <script>
        // 确保DOM加载完成
        document.addEventListener('DOMContentLoaded', function() {
            // 获取canvas元素
            const ctx = document.getElementById('quotaChart').getContext('2d');
            
            // 创建折线图
            const quotaChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['2021', '2022', '2023', '2024', '2025', '2026'],
                    datasets: [{
                        label: '计划名额',
                        data: [22, 22, 22, 22, 19, 18],
                        borderColor: '#004494',
                        backgroundColor: 'rgba(0, 68, 148, 0.1)',
                        borderWidth: 2,
                        fill: true,
                        tension: 0.4, // 平滑折线
                        pointBackgroundColor: '#004494',
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2,
                        pointRadius: 6,
                        pointHoverRadius: 8,
                        pointLabelFont: '12px Arial'
                    }, {
                        label: '统考名额',
                        data: [7, 13, 16, 11, 7, null],
                        borderColor: '#FFA500',
                        backgroundColor: 'rgba(255, 165, 0, 0.1)',
                        borderWidth: 2,
                        fill: true,
                        tension: 0.4, // 平滑折线
                        pointBackgroundColor: '#FFA500',
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2,
                        pointRadius: 6,
                        pointHoverRadius: 8,
                        pointLabelFont: '12px Arial'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: {
                            title: {
                                display: true,
                                text: '年份',
                                font: {
                                    size: 14
                                }
                            },
                            grid: {
                                display: true,
                                color: 'rgba(0, 0, 0, 0.05)'
                            },
                            // 使用barThickness直接设置条形图宽度为18px，不再需要这些百分比设置
                            categoryPercentage: 1 // 确保分类之间有足够空间
                        },
                        y: {
                            title: {
                                display: true,
                                text: '名额数量',
                                font: {
                                    size: 14
                                }
                            },
                            min: 6,
                            max: 24,
                            stepSize: 3,
                            grid: {
                                display: true,
                                color: 'rgba(0, 0, 0, 0.05)'
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            display: true,
                            position: 'top',
                            align: 'end',
                            labels: {
                                usePointStyle: true,
                                font: {
                                    size: 12
                                }
                            }
                        },
                        // 自定义插件：添加数据标签
                        afterDraw: function(chart) {
                            var ctx = chart.ctx;
                            chart.data.datasets.forEach(function(dataset, datasetIndex) {
                                if (dataset.data.length > 0) {
                                    chart.getDatasetMeta(datasetIndex).data.forEach(function(point, index) {
                                        // 检查数据是否存在
                                        if (dataset.data[index] !== null) {
                                            // 获取点的位置
                                            var x = point.getCenterPoint().x;
                                            var y = point.getCenterPoint().y;
                                            
                                            // 根据数据集选择颜色
                                            var labelColor = datasetIndex === 0 ? '#004494' : '#FFA500';
                                            
                                            // 设置文字样式
                                            ctx.fillStyle = labelColor;
                                            ctx.font = 'bold 12px Arial';
                                            ctx.textAlign = 'center';
                                            ctx.textBaseline = 'bottom';
                                            
                                            // 绘制数据标签
                                            ctx.fillText(dataset.data[index], x, y - 10);
                                        }
                                    });
                                }
                            });
                        },
                        tooltip: {
                            mode: 'index',
                            intersect: false,
                            backgroundColor: 'rgba(0, 0, 0, 0.8)',
                            titleFont: {
                                size: 14
                            },
                            bodyFont: {
                                size: 12
                            },
                            padding: 12,
                            cornerRadius: 4
                        }
                    }
                }
            });

            // 初始化报考人数折线图（带条形图）
            var ctx2 = document.getElementById('applicationChart').getContext('2d');
            new Chart(ctx2, {
                type: 'bar', // 同时支持线图和条形图
                data: {
                    labels: ['2020', '2021', '2022', '2023', '2024', '2025'],
                    datasets: [
                        // 报考人数折线图
                        {
                            label: '报考人数',
                            type: 'line',
                            data: [232, 147, 151, 117, 152, 105],
                            borderColor: '#004494',
                            backgroundColor: 'rgba(0, 68, 148, 0)', // 完全透明，移除填充阴影
                            borderWidth: 2,
                            fill: true,
                            tension: 0.4, // 平滑折线
                            pointBackgroundColor: '#004494',
                            pointBorderColor: '#fff',
                            pointBorderWidth: 2,
                            pointRadius: 6,
                            pointHoverRadius: 8,
                            yAxisID: 'y'
                        },
                        // 条形图数据集
                        {
                            label: '报录比',
                            type: 'bar',
                            data: [13.65, 21, 11.62, 7.31, 13.82, 15],
                            backgroundColor: '#FFE4C4',
                            borderColor: '#FFE4C4',
                            borderWidth: 1,
                            borderRadius: { topLeft: 10, topRight: 10 }, // 顶部弧形设计
                            barThickness: 26, // 设置条形图宽度为26px
                            yAxisID: 'y1'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: {
                            title: {
                                display: true,
                                text: '年份',
                                font: {
                                    size: 14
                                }
                            },
                            grid: {
                                display: true,
                                color: 'rgba(0, 0, 0, 0.05)'
                            }
                        },
                        // 主要纵坐标轴
                        y: {
                            title: {
                                display: true,
                                text: '报考人数',
                                font: {
                                    size: 14
                                }
                            },
                            min: 90,
                            max: 240,
                            stepSize: 30,
                            grid: {
                                display: true,
                                color: 'rgba(0, 0, 0, 0.05)'
                            }
                        },
                        // 次要纵坐标轴
                        y1: {
                            position: 'right',
                            title: {
                                display: false, // 隐藏次要纵坐标轴标题
                            },
                            min: 0,
                            max: 25,
                            stepSize: 5,
                            grid: {
                                drawOnChartArea: false
                            },
                            ticks: {
                                callback: function(value) {
                                    // 直接返回刻度值，去掉括号及其内容
                                    return value;
                                }
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            display: true,
                            position: 'top',
                            align: 'end',
                            labels: {
                                usePointStyle: true,
                                font: {
                                    size: 12
                                }
                            }
                        },
                        // 自定义插件：添加数据标签
                        afterDraw: function(chart) {
                            var ctx = chart.ctx;
                            chart.data.datasets.forEach(function(dataset, datasetIndex) {
                                if (dataset.data.length > 0) {
                                    chart.getDatasetMeta(datasetIndex).data.forEach(function(point, index) {
                                        // 检查数据点是否存在且有值
                                        if (point && dataset.data[index] !== null && dataset.data[index] !== undefined) {
                                            // 获取点的位置
                                            var x = point.getCenterPoint().x;
                                            var y;
                                            
                                            // 根据图表类型设置不同的Y坐标
                                            if (dataset.type === 'line') {
                                                y = point.getCenterPoint().y;
                                                // 设置文字样式
                                                ctx.fillStyle = '#004494';
                                                ctx.font = 'bold 12px Arial';
                                                ctx.textAlign = 'center';
                                                ctx.textBaseline = 'bottom';
                                                // 在折线图每个点上方10px处绘制数据标签
                                                ctx.fillText(dataset.data[index], x, y - 10);
                                            } else if (dataset.type === 'bar') {
                                                y = point.y + 15;
                                                // 设置文字样式
                                                ctx.fillStyle = '#FFA500';
                                                ctx.font = 'bold 12px Arial';
                                                ctx.textAlign = 'center';
                                                ctx.textBaseline = 'top';
                                                // 绘制数据标签
                                                ctx.fillText(dataset.data[index], x, y);
                                            }
                                        }
                                    });
                                }
                            });
                        },
                        tooltip: {
                            mode: 'index',
                            intersect: false,
                            backgroundColor: 'rgba(0, 0, 0, 0.8)',
                            titleFont: {
                                size: 14
                            },
                            bodyFont: {
                                size: 12
                            },
                            padding: 12,
                            cornerRadius: 4
                        }
                    }
                }
            });

            // 创建复试分数线与国家线折线图
            const ctx3 = document.getElementById('reexaminationScoreChart').getContext('2d');
            const reexaminationScoreChart = new Chart(ctx3, {
                type: 'line',
                data: {
                    labels: ['2020', '2021', '2022', '2023', '2024', '2025'],
                    datasets: [
                        // 复试分数折线
                        {
                            label: '复试分数',
                            data: [343, 358, 382, 346, 367, 356],
                            borderColor: 'orange',
                            backgroundColor: 'rgba(255, 165, 0, 0.1)',
                            borderWidth: 3,
                            fill: true,
                            tension: 0.4,
                            pointBackgroundColor: 'orange',
                            pointBorderColor: '#fff',
                            pointBorderWidth: 2,
                            pointRadius: 8,
                            pointHoverRadius: 10,
                            pointStyle: 'circle',
                            yAxisID: 'y'
                        },
                        // 国家线折线
                        {
                            label: '国家线',
                            data: [343, 348, 360, 346, 338, 323],
                            borderColor: '#4682B4',
                            backgroundColor: 'rgba(70, 130, 180, 0.1)',
                            borderWidth: 3,
                            fill: true,
                            tension: 0.4,
                            pointBackgroundColor: '#4682B4',
                            pointBorderColor: '#fff',
                            pointBorderWidth: 2,
                            pointRadius: 8,
                            pointHoverRadius: 10,
                            pointStyle: 'rect',
                            yAxisID: 'y'
                        },
                        // 录取最低分折线
                        {
                            label: '录取最低分',
                            data: [null, null, null, 346, 367, 361],
                            borderColor: '#F08080',
                            backgroundColor: 'rgba(240, 128, 128, 0.1)',
                            borderWidth: 3,
                            fill: true,
                            tension: 0.4,
                            pointBackgroundColor: '#F08080',
                            pointBorderColor: '#fff',
                            pointBorderWidth: 2,
                            pointRadius: 8,
                            pointHoverRadius: 10,
                            pointStyle: 'triangle',
                            yAxisID: 'y'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: {
                            title: {
                                display: true,
                                text: '年份',
                                font: {
                                    size: 14
                                }
                            },
                            grid: {
                                display: true,
                                color: 'rgba(0, 0, 0, 0.05)'
                            }
                        },
                        y: {
                            title: {
                                display: true,
                                text: '分数',
                                font: {
                                    size: 14
                                }
                            },
                            min: 320,
                            max: 390,
                            stepSize: 10,
                            grid: {
                                display: true,
                                color: 'rgba(0, 0, 0, 0.05)'
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            display: true,
                            position: 'top',
                            align: 'end',
                            labels: {
                                usePointStyle: true,
                                font: {
                                    size: 12
                                }
                            }
                        },
                        tooltip: {
                            mode: 'index',
                            intersect: false,
                            backgroundColor: 'rgba(0, 0, 0, 0.8)',
                            titleFont: {
                                size: 14
                            },
                            bodyFont: {
                                size: 12
                            },
                            padding: 12,
                            cornerRadius: 4
                        }
                    }
                }
            });

            // 创建2025年复试专业课分数段分析条形图
            const ctx4 = document.getElementById('professionalScoreChart').getContext('2d');
            const professionalScoreChart = new Chart(ctx4, {
                type: 'bar',
                data: {
                    labels: ['110～119', '120～129', '130～139', '140～149'],
                    datasets: [{
                        label: '人数',
                        data: [1, 1, 6, 1],
                        backgroundColor: '#4682B4',
                        borderColor: '#4682B4',
                        borderWidth: 1,
                        borderRadius: 4,
                        barThickness: 35 // 设置条形图宽度为35px
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: {
                            title: {
                                display: true,
                                text: '分数段',
                                font: {
                                    size: 14
                                }
                            },
                            grid: {
                                display: false
                            }
                        },
                        y: {
                            title: {
                                display: true,
                                text: '人数',
                                font: {
                                    size: 14
                                }
                            },
                            min: 0,
                            max: 6,
                            stepSize: 1,
                            grid: {
                                display: true,
                                color: 'rgba(0, 0, 0, 0.05)'
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            display: false
                        },
                        // 自定义插件：添加数据标签
                        afterDraw: function(chart) {
                            var ctx = chart.ctx;
                            chart.data.datasets.forEach(function(dataset, datasetIndex) {
                                if (dataset.data.length > 0) {
                                    chart.getDatasetMeta(datasetIndex).data.forEach(function(point, index) {
                                        // 检查数据点是否存在且有值
                                        if (point && dataset.data[index] !== null && dataset.data[index] !== undefined) {
                                            // 获取点的位置
                                            var x = point.getCenterPoint().x;
                                            var y = point.y + 15;
                                            
                                            // 设置文字样式
                                            ctx.fillStyle = '#333';
                                            ctx.font = 'bold 12px Arial';
                                            ctx.textAlign = 'center';
                                            ctx.textBaseline = 'top';
                                            // 绘制数据标签
                                            ctx.fillText(dataset.data[index], x, y);
                                        }
                                    });
                                }
                            });
                        },
                        tooltip: {
                            mode: 'index',
                            intersect: false,
                            backgroundColor: 'rgba(0, 0, 0, 0.8)',
                            titleFont: {
                                size: 14
                            },
                            bodyFont: {
                                size: 12
                            },
                            padding: 12,
                            cornerRadius: 4
                        }
                    }
                }
            });
            
            // 创建分数段分布分析条形图
            const ctx5 = document.getElementById('scoreDistributionChart').getContext('2d');
            const scoreDistributionChart = new Chart(ctx5, {
                type: 'bar',
                data: {
                    labels: ['100～109', '110～119', '120～129', '130～139'],
                    datasets: [{
                        label: '人数',
                        data: [3, 5, 4, 2],
                        backgroundColor: '#4682B4',
                        borderColor: '#4682B4',
                        borderWidth: 1,
                        borderRadius: 4,
                        barThickness: 35 // 设置条形图宽度为35px，与现有条形图一致
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: {
                            title: {
                                display: true,
                                text: '分数段',
                                font: {
                                    size: 14
                                }
                            },
                            grid: {
                                display: false
                            }
                        },
                        y: {
                            title: {
                                display: true,
                                text: '人数',
                                font: {
                                    size: 14
                                }
                            },
                            min: 0,
                            max: 6,
                            stepSize: 1,
                            grid: {
                                display: true,
                                color: 'rgba(0, 0, 0, 0.05)'
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            display: false
                        },
                        // 自定义插件：添加数据标签
                        afterDraw: function(chart) {
                            var ctx = chart.ctx;
                            chart.data.datasets.forEach(function(dataset, datasetIndex) {
                                if (dataset.data.length > 0) {
                                    chart.getDatasetMeta(datasetIndex).data.forEach(function(point, index) {
                                        // 检查数据点是否存在且有值
                                        if (point && dataset.data[index] !== null && dataset.data[index] !== undefined) {
                                            // 获取点的位置
                                            var x = point.getCenterPoint().x;
                                            var y = point.y + 15;
                                            
                                            // 设置文字样式
                                            ctx.fillStyle = '#333';
                                            ctx.font = 'bold 12px Arial';
                                            ctx.textAlign = 'center';
                                            ctx.textBaseline = 'top';
                                            // 绘制数据标签
                                            ctx.fillText(dataset.data[index], x, y);
                                        }
                                    });
                                }
                            });
                        },
                        tooltip: {
                            mode: 'index',
                            intersect: false,
                            backgroundColor: 'rgba(0, 0, 0, 0.8)',
                            titleFont: {
                                size: 14
                            },
                            bodyFont: {
                                size: 12
                            },
                            padding: 12,
                            cornerRadius: 4
                        }
                    }
                }
            });
        });
    </script>
    
    <style>
        .chart-container {
            margin-top: 30px;
            height: 400px;
            width: 100%;
            max-width: 800px;
            margin-left: auto;
            margin-right: auto;
        }
    </style>
</body>
</html>

















